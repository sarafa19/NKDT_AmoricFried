	partition Calendrier = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(DATE(2024,1,1), DATE(2026,12,31)),
				    "Année", YEAR([Date]),
				    "Mois", FORMAT([Date], "MMMM"),
				    "Mois Num", MONTH([Date]),
				    "Année-Mois", FORMAT([Date], "YYYY-MM")
				)

	annotation PBI_Id = 9bd35c7408fe4405b9f2358a7474196e

